# ─────────────────────────────────────────────
# Savarun Backend — environment template
# Copy to .env for local dev. On Render, set these in
# Dashboard → your service → Environment.
# NEVER commit the filled-in .env or the service account key.
# ─────────────────────────────────────────────

# Server. Render injects PORT itself — do not set it there.
PORT=4000
NODE_ENV=development

# Comma-separated allowlist, used only when NODE_ENV=production.
# Add the origin your Flutter WEB build is served from.
# Native iOS/Android builds don't send an Origin header and are unaffected.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# The server's own public https origin, e.g. https://savarun-api.onrender.com
# Used to build absolute URLs for uploaded images. Leave blank locally.
PUBLIC_URL=

# ── Firebase Admin SDK ──
# PRODUCTION: paste the entire service-account JSON as ONE line here.
FIREBASE_SERVICE_ACCOUNT_JSON=
# LOCAL DEV: or point at the downloaded file instead (gitignored).
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

FIREBASE_PROJECT_ID=savarun-app-b775b
FIREBASE_STORAGE_BUCKET=

# ── AI vision provider: groq | openai ──
AI_PROVIDER=groq

# ── Groq (OpenAI-compatible, free tier) ──
GROQ_API_KEY=
# qwen3.6-27b is the vision model available on Groq's free tier.
GROQ_VISION_MODEL=qwen/qwen3.6-27b

# ── OpenAI (only used when AI_PROVIDER=openai) ──
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
