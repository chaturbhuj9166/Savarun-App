rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // ── User profiles ──
    match /users/{uid} {
      // Any signed-in user can view a profile; only the owner edits it.
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;

      // Wardrobe items: owner has full access; others can read only when
      // the owner's wardrobe is public.
      match /wardrobe/{itemId} {
        allow read: if isOwner(uid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/users/$(uid)).data.wardrobePublic == true);
        allow write: if isOwner(uid);
      }

      // Outfit sets belong to the owner only.
      match /outfits/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Outfit History — the analyses the backend saves. The owner always
      // reads their own; others only when the profile's wardrobe is public,
      // which is what puts past Fit Scores on a public profile.
      // Writes come from the backend (Admin SDK), which bypasses these rules.
      match /outfitHistory/{docId} {
        allow read: if isOwner(uid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/users/$(uid)).data.wardrobePublic == true);
        allow write: if isOwner(uid);
      }
    }

    // ── Follows (edges: doc id `${followerUid}_${followingUid}`) ──
    match /follows/{edgeId} {
      allow read: if isSignedIn();
      // You may only create/delete edges where YOU are the follower.
      allow create: if isSignedIn() && request.resource.data.followerUid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerUid == request.auth.uid;
      allow update: if false;
    }

    // ── Chats (1-on-1) ──
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ── Brands & products (managed by the backend admin SDK) ──
    match /brands/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /products/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
